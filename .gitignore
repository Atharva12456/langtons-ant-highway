# ---- LaTeX build artifacts ----
*.aux
*.log
*.out
*.toc
*.bbl
*.blg
*.fls
*.fdb_latexmk
*.synctex.gz
*.pdf
!docs/**/*.pdf

# ---- Lean build output (regenerated by `lake build`) ----
lean/.lake/
lean/build/
**/*.olean
**/*.ilean
**/*.trace

# ---- Lean toolchain (huge; installed via elan, never committed) ----
lean_toolchain/
**/.elan/

# ---- Java build output ----
build/
**/*.class

# ---- Python ----
__pycache__/
*.pyc
.venv/
venv/

# ---- Large search shard data (regenerate with the commands in README) ----
# Keep results/ summaries; ignore any bulk shard dumps a contributor generates.
**/p*_shards*/
**/*_shards_*/
shard_*.json
*_complete.json
!results/*.json

# ---- OS / editor cruft ----
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/

# Build cruft (Java classes, stray LaTeX out dir, scratch)
indep_classes/
tmp/
paper/$out/
*.class
compile.done
p[0-9].log
